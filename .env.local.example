# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Nozomio Nia (employee context)
# Nia docs use NIA_API_KEY; NOZOMIO_API_KEY is still accepted by the app.
NIA_API_KEY=
NOZOMIO_API_KEY=
# Optional override:
# NIA_BASE_URL=https://apigcp.trynia.ai/v2
# Optional comma-separated scoping for demos:
# NIA_REPOSITORIES=owner/repo
# NIA_DATA_SOURCES=Slack Export,OpenFire Docs

# AgentMail (email send + inbound webhook)
AGENTMAIL_API_KEY=
AGENTMAIL_WEBHOOK_SECRET=
AGENTMAIL_INBOX_ADDRESS=claw@your-domain.example
# Optional override:
# AGENTMAIL_BASE_URL=https://api.agentmail.to

# Anthropic / Claude
ANTHROPIC_API_KEY=

# Google Calendar (exit interview scheduling)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# GitHub (digital employees with a github resource use this token to
# create real issues. Without it, dispatch returns a simulated response.)
# Personal access token with `repo` scope.
GITHUB_TOKEN=
